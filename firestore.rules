rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Contact statements: sensitive. All reads and writes go through Cloud Functions
    // (Admin SDK), which enforce signature verification and trust-path proof.
    // No direct client access.
    match /hablotengo_contact/{delegateToken}/statements/{statementId} {
      allow read, write: if false;
    }

    // Privacy (permissive/strict) and override statements: public reads.
    // Writes go through Cloud Functions (signature verification).
    match /hablotengo_privacy/{delegateToken}/statements/{statementId} {
      allow read: if true;
      allow write: if false;
    }

    match /hablotengo_override/{delegateToken}/statements/{statementId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
