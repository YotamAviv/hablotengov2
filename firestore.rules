rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Statement collections: public read, authenticated write.
    // Cryptographic signature verification happens client-side; the signer's
    // public key is embedded in the statement. A Cloud Function can enforce
    // stricter validation if needed.
    match /hablotengo_contact/{delegateToken}/statements/{statementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /hablotengo_privacy/{delegateToken}/statements/{statementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /hablotengo_override/{delegateToken}/statements/{statementId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
