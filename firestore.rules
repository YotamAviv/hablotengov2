rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Session handshake: CF writes via admin SDK; web app reads via client SDK.
    match /sessions/{doc}/{session}/{document} {
      allow read: if true;
    }

    // Contact records: one document per identity token.
    // Reads are served by cloud functions (admin SDK); no direct client reads.
    match /contacts/{identityToken} {
      allow write: if false;
      allow read: if false;
    }

  }
}
