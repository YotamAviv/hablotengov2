{
  "firestore": {
    "rules": "oneofus.firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "host": "127.0.0.1",
      "port": "5004",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "emulators": {
    "firestore": {
      "port": 8083,
      "websocketPort": 9153
    },
    "functions": {
      "host": "127.0.0.1",
      "port": "5004"
    },
    "hub": {
      "port": 4403
    },
    "ui": {
      "enabled": true,
      "port": 4003
    },
    "eventarc": {
      "port": 9303
    },
    "tasks": {
      "port": 9503
    },
    "logging": {
      "port": 4503
    }
  }
}
